// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  STAFF
  KITCHEN
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
}

enum OrderStatus {
  PENDING
  COOKING
  SERVED
  CANCELLED
}

enum PaymentMethod {
  CASH
  VNPAY
  MOMO
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}

model User {
  id           String    @id @default(uuid())
  username     String    @unique @db.VarChar(50)
  fullName     String    @map("full_name") @db.VarChar(50)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  role         Role      @default(STAFF)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime? @updatedAt @map("updated_at") @db.Timestamptz(3)

  @@map("users")
}

model Table {
  id        String      @id @default(uuid())
  name      String      @unique @db.VarChar(50)
  status    TableStatus @default(AVAILABLE)
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime?   @updatedAt @map("updated_at") @db.Timestamptz(3)

  sessions DiningSession[]

  @@map("tables")
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique @db.VarChar(100)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamptz(3)

  products Product[]

  @@map("categories")
}

model Product {
  id          String    @id @default(uuid())
  categoryId  String    @map("category_id")
  name        String    @unique @db.VarChar(150)
  price       Decimal   @db.Decimal(10, 2)
  imageUrl    String?   @map("image_url") @db.Text
  isAvailable Boolean   @default(true) @map("is_available")
  isBuffet    Boolean   @default(false) @map("is_buffet")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt   DateTime? @updatedAt @map("updated_at") @db.Timestamptz(3)

  category   Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@map("products")
}

model DiningSession {
  id           String    @id @default(uuid())
  tableId      String    @map("table_id")
  customerName String?   @map("customer_name") @db.VarChar(100)
  startTime    DateTime  @default(now()) @map("start_time") @db.Timestamptz(3)
  endTime      DateTime? @map("end_time") @db.Timestamptz(3)
  isClosed     Boolean   @default(false) @map("is_closed") // Kiểm soát phiên ăn đã checkout chưa
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt    DateTime? @updatedAt @map("updated_at") @db.Timestamptz(3)

  table    Table     @relation(fields: [tableId], references: [id], onDelete: Restrict)
  orders   Order[] // Một phiên ăn khách có thể nhấn "Gửi bếp" nhiều lần
  invoice  Invoice? // Một phiên ăn chỉ có duy nhất 1 hóa đơn chốt tiền
  feedback Feedback? // Một phiên ăn chỉ có duy nhất 1 lượt đánh giá

  @@map("dining_sessions")
}

model Order {
  id         String      @id @default(uuid())
  sessionId  String      @map("session_id")
  status     OrderStatus @default(PENDING)
  totalPrice Decimal     @default(0) @map("total_price") @db.Decimal(10, 2)
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime?   @updatedAt @map("updated_at") @db.Timestamptz(3)

  session    DiningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String    @id @default(uuid())
  orderId   String    @map("order_id")
  productId String    @map("product_id")
  quantity  Int       @db.SmallInt
  unitPrice Decimal   @map("unit_price") @db.Decimal(10, 2)
  note      String?   @db.VarChar(500)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamptz(3)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@map("order_items")
}

model Invoice {
  id            String        @id @default(uuid())
  sessionId     String        @unique @map("session_id") // 1-1 với DiningSession
  amount        Decimal       @db.Decimal(10, 2) // Tiền hàng trước thuế
  taxAmount     Decimal?      @default(0) @map("tax_amount") @db.Decimal(10, 2) // Tiền thuế VAT (nếu có)
  finalAmount   Decimal       @map("final_amount") @db.Decimal(10, 2) // Tổng tiền khách phải trả thực tế
  status        InvoiceStatus @default(PENDING)
  paymentMethod PaymentMethod @default(CASH) @map("payment_method")
  transactionId String?       @map("transaction_id") @db.VarChar(100) // Mã đối soát từ cổng VNPay/Momo
  paidAt        DateTime?     @map("paid_at") @db.Timestamptz(3)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)

  session DiningSession @relation(fields: [sessionId], references: [id], onDelete: Restrict)

  @@map("invoices")
}

model Feedback {
  id        String   @id @default(uuid())
  sessionId String   @unique @map("session_id") // 1-1 với DiningSession
  rating    Int      @db.SmallInt
  comment   String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  session DiningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("feedbacks")
}
